# ─── JWT Keys (leave empty — keys are read from files in keys/) ───
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ─── Database URLs ───
DATABASE_URL_USERS=postgresql+psycopg2://postgres:postgres@postgres:5432/users
DATABASE_URL_PRODUCTS=postgresql+psycopg2://postgres:postgres@postgres:5432/products
DATABASE_URL_ORDERS=postgresql+psycopg2://postgres:postgres@postgres:5432/orders
DATABASE_URL_BILLING=postgresql+psycopg2://postgres:postgres@postgres:5432/billing
DATABASE_URL_NOTIFICATIONS=postgresql+psycopg2://postgres:postgres@postgres:5432/notifications

# ─── Service URLs ───
USER_SERVICE_URL=http://user-service:8000
PRODUCT_SERVICE_URL=http://product-service:8000
CART_SERVICE_URL=http://cart-service:8000
BILLING_SERVICE_URL=http://billing-service:8000
AUTH_SERVICE_URL=http://auth-service:8000

# ─── Broker ───
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_AVAILABLE=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ─── App ───
ALLOWED_ORIGINS=http://localhost
APP_VERSION=0.1.0

# ─── Auth ───
ACCESS_TOKEN_EXPIRE=15
REFRESH_TOKEN_EXPIRE=7

# ─── Cart ───
CART_TTL=604800

# ─── Orders ───
SAGA_TIMEOUT=300
